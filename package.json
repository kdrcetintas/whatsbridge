{
  "name": "whatsbridge",
  "version": "1.0.16",
  "description": "WhatsBridge — WhatsApp REST API server with web dashboard",
  "main": "dist/cli.js",
  "bin": {
    "whatsbridge": "dist/cli.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc",
    "package": "npm run build && node scripts/package.js",
    "dev": "ts-node src/cli.ts",
    "start": "node dist/cli.js start",
    "prepare": "npm run build"
  },
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcryptjs": "^3.0.3",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "inquirer": "^8.2.7",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/inquirer": "^8.2.12",
    "@types/node": "^25.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/sql.js": "^1.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "pkg": {
    "assets": [
      "public/**",
      "vendor/**"
    ],
    "scripts": [
      "node_modules/sql.js/dist/sql-asm.js"
    ]
  }
}
